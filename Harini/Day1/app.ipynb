   "source": [
    "from fastapi import FastAPI\n",
    "\n",
    "app = FastAPI()\n",
    "\n",
    "@app.get(\"/\")\n",
    "def home():\n",
    "    return {\"message\": \"Welcome\"}\n",
    "\n",
    "@app.get(\"/hello\")\n",
    "def hello(name: str = \"Guest\"):\n",
    "    return {\"message\": f\"Hello, {name}\"}"
   ]
